    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python: console",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/demo/console_board.py",
            "args": [""],
            "python": "${workspaceFolder}/env/bin/python",
            "console": "integratedTerminal"            
        },
        {
            "name": "Python: pygame",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/demo/pygame_dirty.py",
            "args": [""],
            "python": "${workspaceFolder}/env/bin/python",
            "console": "integratedTerminal"            
        },
        {
            "name": "Python: tokenizer_parser_pdn",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/demo/tokenizer_parser_pdn.py",
            "args": [""],
            "python": "${workspaceFolder}/env/bin/python",
            "console": "integratedTerminal"            
        },
        {
            "name": "Python: checkers",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/checkers/checkers_main.py",
            "args": ["config.ini"],
            "python": "${workspaceFolder}/env/bin/python",
            "console": "integratedTerminal",   
            "justMyCode": true,
        },
        {
            "name": "Python: checkers multiprocess",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/checkers/checkers_main.py",
            "args": ["config_play.ini"],
            "python": "${workspaceFolder}/env/bin/python",
            "console": "integratedTerminal",   
            "justMyCode": false,
            "subProcess": true
        },


    ]
}
